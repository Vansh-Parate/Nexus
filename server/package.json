{
  "name": "vega-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "prisma generate",
    "dev": "node --watch server.js",
    "start": "node server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:add-columns": "node prisma/run-add-columns.js",
    "db:seed": "node prisma/seed.js",
    "ml:build": "python scripts/build_regression_data.py",
    "ml:train": "python scripts/train_model.py",
    "ml:setup": "npm run ml:build && npm run ml:train"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "prisma": "^5.22.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {}
}
