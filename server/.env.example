# Database
DATABASE_URL=your_database_url_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS (required for production)
# Set this to your frontend deployment URL, e.g.:
# FRONTEND_URL=https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Server Port (Render sets this automatically, but you can override)
PORT=3001

# Add any other environment variables your backend needs here
