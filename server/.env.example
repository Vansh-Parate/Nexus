DATABASE_URL="postgresql://user:password@localhost:5432/vega?schema=public"
JWT_SECRET="change-this-in-production"
PORT=3001

# SMTP — required for investors to receive pitch emails
# Gmail: use App Password (Google Account → Security → 2-Step Verification → App passwords)
# Mailtrap (testing): https://mailtrap.io — use their SMTP host/user/pass
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=VEGA <your-email@gmail.com>

# Frontend URL — used for pitch deck and login links in emails
FRONTEND_URL=http://localhost:5173

# Gemini API — for AI pitch generation in profile form
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
