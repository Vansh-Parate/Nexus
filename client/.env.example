# API Base URL (without trailing slash)
# For production, set this to your Render backend URL, e.g.:
# VITE_API_URL=https://vega-backend.onrender.com/api
# Leave empty or use '/api' if frontend and backend are on same domain
VITE_API_URL=

# WebSocket URL (full URL including protocol)
# For production, set this to your Render backend WebSocket URL, e.g.:
# VITE_WS_URL=wss://vega-backend.onrender.com/ws
# Leave empty to auto-detect from current host
VITE_WS_URL=
