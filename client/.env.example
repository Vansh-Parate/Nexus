# API Base URL (without trailing slash)
# REQUIRED when frontend (e.g. Vercel) and backend (e.g. Render) are on different domains:
# VITE_API_URL=https://vega-issj.onrender.com/api
# Leave empty only if frontend and backend are on the same domain (e.g. local dev with proxy)
VITE_API_URL=

# WebSocket URL (full URL including protocol)
# For production, set this to your Render backend WebSocket URL, e.g.:
# VITE_WS_URL=wss://vega-backend.onrender.com/ws
# Leave empty to auto-detect from current host
VITE_WS_URL=
